# =====================================================================
#  GastroDigest · Variables de entorno (plantilla)
#  Copie este archivo a .env y complete los valores. NUNCA suba .env.
# =====================================================================

# ---- Aplicación ----
APP_ENV=production            # local | production
APP_URL=                      # URL pública del backend (Railway), ej. https://api.gastrodigest.up.railway.app
APP_FRONTEND_URL=             # URL del frontend (Vercel), ej. https://gastrodigest.vercel.app  (requerido por el portal/CORS)

# ---- Base de datos (MySQL · Railway) ----
DB_HOST=                      # Railway: variable MYSQLHOST
DB_PORT=3306                  # Railway: variable MYSQLPORT
DB_NAME=gastrodigest          # Railway: variable MYSQLDATABASE
DB_USER=                      # Railway: variable MYSQLUSER
DB_PASS=                      # Railway: variable MYSQLPASSWORD

# ---- n8n (orquestador) ----
N8N_WEBHOOK_BASE_URL=         # ej. https://n8n.gastrodigest.up.railway.app
N8N_WEBHOOK_SECRET=           # secreto compartido para firmar/verificar webhooks

# ---- Mensajería ----
WHATSAPP_API_TOKEN=           # token de WhatsApp Cloud API (lo usa n8n)
