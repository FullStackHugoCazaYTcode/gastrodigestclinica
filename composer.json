{
  "name": "gastrodigest/backend",
  "description": "GastroDigest — backend PHP 8.2 (MVC + PDO). Composer se usa solo para el tooling de pruebas; la app en runtime usa su propio autoloader.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "classmap": [
      "backend/core",
      "backend/models",
      "backend/controllers",
      "backend/services",
      "backend/middlewares"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  }
}
